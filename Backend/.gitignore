# ###########################################################
# METRO-HCM - Backend Local .gitignore
# ###########################################################

# --- DEPENDENCIES ---
node_modules/
.pnp
.pnp.js

# --- BUILD & OUTPUT ---
dist/
build/
bin/
out/
.vercel/
.output/

# --- SECRETS & ENVIRONMENT (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
serviceAccountKey.json
src/config/serviceAccountKey.json
# Credentials
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12

# --- LOGS & DIAGNOSTICS ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# Debug files/Temporary (Project Specific)
debug_write.txt
test_*.js
sanity_check*.js
debug.txt

# --- COVERAGE ---
coverage/
.nyc_output/
.eslintcache
.prettiercache

# --- IDE & SYSTEM ---
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.patch
*.diff

# --- DATABASE / CACHE ---
*.sqlite
*.db
dump.rdb
.firebase/
firebase-debug.log*
.firebaserc
